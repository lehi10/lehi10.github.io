---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<BaseLayout
	title="About — Lehi Quincho"
	description="Agentic Engineer with 5+ years of experience building web, mobile and AI-powered applications. Based in Lima, Perú."
>
	<main class="wrapper about">

		<header class="about-header">
			<h1>About me</h1>
			<p class="subtitle">
				Agentic Engineer with 5+ years building web, mobile and AI-powered products
				across logistics, fintech and SaaS. Based in Lima, Perú.
			</p>
		</header>

		<div class="about-grid">
			<section class="section">
				<h2>Background</h2>
				<div class="prose">
					<p>
						I build AI-powered applications and agentic systems — workflows where LLMs reason,
						use tools, and take actions. My stack spans React, Node.js, Python and mobile,
						so I can own the full loop from UI to agent backend.
					</p>
					<p>
						At Globant I've shipped multi-platform projects for global clients (Grifols, JMFamily,
						CashPak) — mobile apps on the App Store and Google Play, Blazor design systems, and
						fintech features. Before that I led frontend at Skillmapper, building B2B/B2C platforms
						and a Chrome Extension from scratch.
					</p>
					<p>
						I use Claude Code and GitHub Copilot every day — not as autocomplete, but as
						collaborators for architecture, multi-file refactors and complex problem solving.
						That's what shaped the move into agentic engineering.
					</p>
				</div>
			</section>

			<section class="section">
				<h2>Education</h2>
				<div class="prose">
					<p>
						<strong>Bachelor's in Computer Science</strong><br />
						Universidad Nacional de San Agustín (UNSA), Arequipa, Perú
					</p>
					<p>
						Participated in <strong>ICPC South America</strong> contests.
						Competitive programming background that sharpened algorithmic thinking.
					</p>
				</div>
			</section>

			<section class="section">
				<h2>Skills</h2>
				<div class="skills-grid">
					<div class="skill-group">
						<h4>Frontend</h4>
						<ul>
							<li>React.js · React Native · Next.js</li>
							<li>TypeScript · JavaScript</li>
							<li>Expo · Material UI · Ant Design</li>
							<li>Redux · TanStack Query</li>
						</ul>
					</div>
					<div class="skill-group">
						<h4>AI Tools</h4>
						<ul>
							<li>Claude Code (Anthropic)</li>
							<li>GitHub Copilot</li>
						</ul>
					</div>
					<div class="skill-group">
						<h4>Backend & DB</h4>
						<ul>
							<li>Node.js · Express.js</li>
							<li>Django (Python)</li>
							<li>PostgreSQL · MySQL · Firebase</li>
						</ul>
					</div>
					<div class="skill-group">
						<h4>Other</h4>
						<ul>
							<li>Blazor · C# · Java</li>
							<li>Chrome Extensions</li>
							<li>Monorepos (pnpm · Yarn WS)</li>
							<li>Azure · OneSignal · Branch.io</li>
						</ul>
					</div>
					<div class="skill-group">
						<h4>Testing</h4>
						<ul>
							<li>Jest · BUnit</li>
							<li>Selenium · JMeter</li>
						</ul>
					</div>
					<div class="skill-group">
						<h4>Soft skills</h4>
						<ul>
							<li>Technical leadership</li>
							<li>Team mentoring</li>
							<li>Technical interviews</li>
							<li>Remote collaboration</li>
						</ul>
					</div>
				</div>
			</section>
		</div>

		<ContactCTA />
	</main>
</BaseLayout>

<style>
	.about {
		padding-top: 3.5rem;
		padding-bottom: 2rem;
	}

	.about-header {
		max-width: 52ch;
		margin-bottom: 3rem;
	}

	.about-header h1 {
		font-size: clamp(2rem, 5vw, var(--text-5xl));
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-bottom: 0.75rem;
	}

	.subtitle {
		font-size: var(--text-lg);
		color: var(--gray-400);
		line-height: 1.6;
	}

	.about-grid {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.section h2 {
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--gray-0);
		letter-spacing: -0.02em;
		margin-bottom: 1.25rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.prose {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.prose p {
		font-size: var(--text-md);
		color: var(--gray-300);
		line-height: 1.7;
		max-width: 64ch;
	}

	.prose strong {
		color: var(--gray-100);
		font-weight: 600;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem 2rem;
	}

	.skill-group h4 {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--gray-400);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.625rem;
	}

	.skill-group ul {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.skill-group li {
		font-size: var(--text-sm);
		color: var(--gray-300);
		font-family: var(--font-mono);
	}

	@media (min-width: 50em) {
		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
