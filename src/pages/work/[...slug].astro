---
import { type CollectionEntry, getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Icon from '../../components/Icon.astro';
import { render } from 'astro:content';

interface Props {
	entry: CollectionEntry<'work'> | CollectionEntry<'projects'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	const projects = await getCollection('projects');
	return [
		...work.map((entry) => ({ params: { slug: entry.id }, props: { entry } })),
		...projects.map((entry) => ({ params: { slug: entry.id }, props: { entry } })),
	];
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="page-wrap">
		<header class="proj-header wrapper">
			<a class="back-link" href="/work/">
				<Icon icon="arrow-left" size="0.9em" /> Work
			</a>

			<div class="proj-meta">
				<h1 class="proj-title">{entry.data.title}</h1>
				<p class="proj-desc">{entry.data.description}</p>

				<div class="proj-row">
					<div class="proj-tags">
						{entry.data.tags.map((t) => <span class="ptag">{t}</span>)}
					</div>
					{'lastCommit' in entry.data && entry.data.lastCommit && (
						<div class="last-commit">
							<Icon icon="github-logo" size="0.9em" />
							<span>Last commit: {entry.data.lastCommit}</span>
							{'url' in entry.data && entry.data.url && (
								<a href={entry.data.url} target="_blank" rel="noopener">View repo →</a>
							)}
						</div>
					)}
				</div>
			</div>
		</header>

		<main class="wrapper">
			<div class="project-body">
				<div class="content">
					<Content />
				</div>
				{'images' in entry.data && entry.data.images && entry.data.images.length > 0 && (
					<aside class="project-images">
						{entry.data.images.map((img: { src: string; alt?: string }) => (
							<div class="project-img-wrap">
								<img src={img.src} alt={img.alt || ''} />
							</div>
						))}
					</aside>
				)}
			</div>
		</main>

		<div class="wrapper">
			<ContactCTA />
		</div>
	</div>
</BaseLayout>

<style>
	/* ── Header ── */
	.proj-header {
		padding-top: 1.75rem;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid #30363d;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.8125rem;
		color: #58a6ff;
		text-decoration: none;
		margin-bottom: 1.25rem;
		transition: opacity 0.15s;
	}
	.back-link:hover { opacity: 0.75; text-decoration: none; }

	.proj-meta {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.proj-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #e6edf3;
		letter-spacing: -0.02em;
		line-height: 1.25;
	}

	.proj-desc {
		font-size: 0.875rem;
		color: #8b949e;
		line-height: 1.6;
		max-width: 64ch;
	}

	.proj-row {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.375rem;
	}

	.proj-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
	}

	.ptag {
		background: #21262d;
		color: #8b949e;
		border: 1px solid #30363d;
		border-radius: 4px;
		padding: 0.15rem 0.5rem;
		font-size: 0.6875rem;
		font-weight: 500;
		font-family: var(--font-mono);
	}

	.last-commit {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.75rem;
		color: #6e7681;
		font-family: var(--font-mono);
	}
	.last-commit a { color: #58a6ff; text-decoration: none; }
	.last-commit a:hover { text-decoration: underline; }

	/* ── Body ── */
	.project-body {
		padding: 2.5rem 0 3rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: start;
	}

	@media (min-width: 768px) {
		.project-body { grid-template-columns: 1fr 280px; }
	}

	/* ── Content ── */
	.content { min-width: 0; }
	.content > :global(* + *) { margin-top: 0.875rem; }

	.content :global(h2),
	.content :global(h3) {
		font-size: 0.9375rem;
		font-weight: 600;
		color: #e6edf3;
		margin: 1.75rem 0 0.625rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid #21262d;
	}

	.content :global(p) {
		font-size: 0.875rem;
		color: #adbac7;
		line-height: 1.7;
	}

	.content :global(ul), .content :global(ol) {
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.content :global(li) {
		font-size: 0.875rem;
		color: #adbac7;
		line-height: 1.6;
	}

	.content :global(strong) { color: #e6edf3; font-weight: 600; }

	.content :global(img) {
		border-radius: 8px;
		border: 1px solid #30363d;
		max-width: 100%;
		height: auto;
		display: block;
	}

	/* ── Right column images ── */
	.project-images {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		position: sticky;
		top: 5rem;
	}

	.project-img-wrap {
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid #30363d;
	}

	.project-img-wrap img {
		width: 100%;
		height: auto;
		display: block;
	}
</style>
