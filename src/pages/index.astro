---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import AITools from '../components/AITools.astro';
import Skills from '../components/Skills.astro';
import Timeline from '../components/Timeline.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Education from '../components/Education.astro';
import Grid from '../components/Grid.astro';
import CallToAction from '../components/CallToAction.astro';

const projects = (await getCollection('projects'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>

	<!-- ── Hero ── -->
	<section class="hero wrapper">
		<div class="hero-text">
			<div class="hero-label">Agentic Engineer</div>
			<h1 class="hero-name">Lehi Quincho</h1>
			<p class="hero-sub">
				Building AI-powered applications and agentic systems.
				Full stack background in React, Node.js and mobile — based in Lima, Perú.
			</p>
			<div class="hero-stack">
				{['Claude Code', 'React', 'Next.js', 'TypeScript', 'Node.js'].map(t => (
					<span class="stack-chip">{t}</span>
				))}
			</div>
			<div class="hero-cta">
				<a href="/work/" class="btn-primary">
					View Work <Icon icon="arrow-right" size="1em" />
				</a>
				<a href="mailto:lqmyacs@gmail.com" class="btn-ghost">
					Contact
				</a>
			</div>
		</div>
		<div class="hero-img">
			<img
				src="/assets/portrait.jpg"
				alt="Lehi Quincho"
				width="320"
				height="400"
			/>
		</div>
	</section>

	<!-- ── Stats ── -->
	<div class="stats-bar wrapper">
		<div class="stat">
			<span class="stat-n">5+</span>
			<span class="stat-l">Years experience</span>
		</div>
		<div class="stat-sep"></div>
		<div class="stat">
			<span class="stat-n">4</span>
			<span class="stat-l">Published apps</span>
		</div>
		<div class="stat-sep"></div>
		<div class="stat">
			<span class="stat-n">AI</span>
			<span class="stat-l">Native workflow</span>
		</div>
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Skills ── -->
	<div class="wrapper">
		<Skills />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── AI Tools ── -->
	<div class="wrapper">
		<AITools />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Experience ── -->
	<div class="wrapper">
		<Timeline />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Education ── -->
	<div class="wrapper">
		<Education />
	</div>

	<div class="divider wrapper"></div>

	<!-- ── Featured Projects ── -->
	<section class="projects wrapper">
		<div class="section-head">
			<h2 class="section-title">Projects</h2>
			<CallToAction href="/work/">
				All work <Icon icon="arrow-right" size="1em" />
			</CallToAction>
		</div>
		<Grid variant="small">
			{projects.map(p => (
				<li><PortfolioPreview project={p} /></li>
			))}
		</Grid>
	</section>

	<!-- ── Contact ── -->
	<div class="wrapper">
		<ContactCTA />
	</div>

</BaseLayout>

<style>
	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		padding-top: 4rem;
		padding-bottom: 3rem;
	}

	.hero-label {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--accent-light);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 0.75rem;
	}

	.hero-name {
		font-size: clamp(2.5rem, 7vw, 5rem);
		font-weight: 800;
		color: var(--gray-0);
		letter-spacing: -0.04em;
		line-height: 1.0;
		margin-bottom: 1.25rem;
	}

	.hero-sub {
		font-size: var(--text-lg);
		color: var(--gray-400);
		line-height: 1.65;
		max-width: 46ch;
		margin-bottom: 1.5rem;
	}
	.hero-sub strong { color: var(--gray-200); font-weight: 600; }

	.hero-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-bottom: 2rem;
	}

	.stack-chip {
		background: var(--gray-800);
		color: var(--gray-300);
		border: 1px solid var(--gray-700);
		border-radius: var(--radius-sm);
		padding: 0.25rem 0.625rem;
		font-size: var(--text-sm);
		font-weight: 500;
		font-family: var(--font-mono);
	}

	.hero-cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.625rem 1.25rem;
		background: var(--gray-0);
		color: var(--gray-999);
		border: 1px solid var(--gray-0);
		border-radius: var(--radius-sm);
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		transition: all var(--theme-transition);
	}
	.btn-primary:hover { background: var(--gray-100); }

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.25rem;
		background: transparent;
		color: var(--gray-300);
		border: 1px solid var(--gray-700);
		border-radius: var(--radius-sm);
		font-size: var(--text-sm);
		font-weight: 500;
		text-decoration: none;
		transition: all var(--theme-transition);
	}
	.btn-ghost:hover { border-color: var(--gray-500); color: var(--gray-0); background: var(--gray-800); }

	.hero-img {
		display: none;
	}

	.hero-img img {
		width: 260px;
		height: 320px;
		object-fit: cover;
		object-position: top;
		border-radius: var(--radius-lg);
		border: 1px solid var(--gray-700);
	}

	/* ── Stats bar ── */
	.stats-bar {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding-block: 1.5rem;
		flex-wrap: wrap;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.stat-n {
		font-size: var(--text-xl);
		font-weight: 800;
		color: var(--gray-0);
		letter-spacing: -0.03em;
		line-height: 1;
	}

	.stat-l {
		font-size: var(--text-sm);
		color: var(--gray-500);
	}

	.stat-sep {
		width: 1px;
		height: 2.5rem;
		background: var(--gray-800);
		flex-shrink: 0;
	}

	/* ── Dividers ── */
	.divider {
		height: 1px;
		background: var(--gray-800);
		margin-block: 0;
	}

	/* ── Projects section ── */
	.projects {
		padding: 4rem 0;
	}

	.section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: var(--text-2xl);
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--gray-0);
	}

	/* ── Desktop layout ── */
	@media (min-width: 50em) {
		.hero {
			flex-direction: row;
			align-items: flex-start;
			justify-content: space-between;
			padding-top: 5rem;
			padding-bottom: 4rem;
			gap: 4rem;
		}

		.hero-text {
			flex: 1;
		}

		.hero-img {
			display: flex;
			flex-shrink: 0;
		}
	}

	@media (min-width: 70em) {
		.hero-img img {
			width: 300px;
			height: 375px;
		}
	}
</style>
