---
---

<section class="ai-section">
	<div class="section-heading">
		AI-Assisted Development
		<span class="ai-badge">Daily workflow</span>
	</div>

	<div class="ai-grid">
		<!-- Claude Code -->
		<div class="ai-card">
			<div class="ai-card-header">
				<div class="ai-icon ai-icon-orange">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
					</svg>
				</div>
				<div>
					<div class="ai-name">Claude Code</div>
					<p class="ai-by">Anthropic</p>
				</div>
			</div>
			<p class="ai-desc">
				CLI agent for complex multi-file work. I use it for architecture decisions,
				large refactors, debugging sessions and cross-file code review.
			</p>
			<div class="ai-uses">
				<span class="use-tag">Architecture</span>
				<span class="use-tag">Refactoring</span>
				<span class="use-tag">Code review</span>
				<span class="use-tag">Debugging</span>
				<span class="use-tag">Multi-file edits</span>
			</div>
		</div>

		<!-- GitHub Copilot -->
		<div class="ai-card">
			<div class="ai-card-header">
				<div class="ai-icon ai-icon-blue">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
					</svg>
				</div>
				<div>
					<div class="ai-name">GitHub Copilot</div>
					<p class="ai-by">GitHub · OpenAI</p>
				</div>
			</div>
			<p class="ai-desc">
				In-editor AI completion integrated in VS Code. Speeds up writing boilerplate,
				generating tests, and completing repetitive patterns inline.
			</p>
			<div class="ai-uses">
				<span class="use-tag">Code completion</span>
				<span class="use-tag">Test generation</span>
				<span class="use-tag">Boilerplate</span>
				<span class="use-tag">Inline suggestions</span>
				<span class="use-tag">PR descriptions</span>
			</div>
		</div>
	</div>
</section>

<style>
	.ai-section { padding: 2rem 0; }

	.section-heading {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--fg-default);
		margin-bottom: 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border-default);
		flex-wrap: wrap;
	}

	.ai-badge {
		background: var(--success-subtle);
		color: var(--success-fg);
		border: 1px solid var(--success-muted);
		border-radius: var(--r-pill);
		padding: 0.125rem 0.5rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	.ai-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border: 1px solid var(--border-default);
		border-radius: var(--r-md);
		overflow: hidden;
	}

	.ai-card {
		padding: 1.25rem;
		background: var(--canvas-subtle);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		border-bottom: 1px solid var(--border-default);
		transition: background var(--theme-transition);
	}
	.ai-card:last-child { border-bottom: none; }
	.ai-card:hover { background: var(--canvas-overlay); }

	.ai-card-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.ai-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: var(--r-sm);
		flex-shrink: 0;
	}

	.ai-icon-orange { background: rgba(240,136,62,.15); color: #f0883e; }
	.ai-icon-blue   { background: rgba(88,166,255,.12); color: var(--accent-fg); }

	.ai-name {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--fg-default);
		letter-spacing: -0.01em;
	}

	.ai-by {
		font-size: var(--text-xs);
		color: var(--fg-subtle);
	}

	.ai-desc {
		font-size: var(--text-sm);
		color: var(--fg-muted);
		line-height: 1.6;
	}

	.ai-uses {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
	}

	.use-tag {
		background: var(--canvas-inset);
		color: var(--fg-muted);
		border: 1px solid var(--border-muted);
		border-radius: var(--r-sm);
		padding: 0.125rem 0.5rem;
		font-size: var(--text-xs);
		font-weight: 500;
	}

	@media (min-width: 640px) {
		.ai-grid {
			grid-template-columns: 1fr 1fr;
		}
		.ai-card { border-bottom: none; border-right: 1px solid var(--border-default); }
		.ai-card:last-child { border-right: none; }
	}
</style>
