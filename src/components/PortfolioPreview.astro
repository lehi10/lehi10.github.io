---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'> | CollectionEntry<'projects'>;
}

const { data, id } = Astro.props.project;
const lastCommit = 'lastCommit' in data ? data.lastCommit : undefined;
const repoUrl = 'url' in data ? data.url : undefined;
---

<a class="card" href={`/work/${id}`}>
	<div class="card-img">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
	</div>
	<div class="card-body">
		<span class="card-title">{data.title}</span>
		<p class="card-desc">{data.description}</p>
		<div class="card-tags">
			{data.tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
		</div>
		{lastCommit && (
			<div class="card-commit">
				<span class="commit-dot"></span>
				{lastCommit}
			</div>
		)}
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--gray-900);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-md);
		overflow: hidden;
		text-decoration: none;
		transition: border-color var(--theme-transition);
		height: 100%;
	}
	.card:hover { border-color: var(--gray-600); }

	.card-img {
		height: 180px;
		overflow: hidden;
		background: var(--gray-800);
	}

	.card-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}
	.card:hover .card-img img { transform: scale(1.04); }

	.card-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.card-title {
		font-size: var(--text-md);
		font-weight: 700;
		color: var(--gray-0);
		letter-spacing: -0.01em;
	}

	.card-desc {
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.55;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		margin-top: 0.25rem;
	}

	.tag {
		background: var(--gray-800);
		color: var(--gray-500);
		border: 1px solid var(--gray-700);
		border-radius: 4px;
		padding: 0.15rem 0.5rem;
		font-size: 0.7rem;
		font-weight: 500;
		font-family: var(--font-mono);
	}

	.card-commit {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.7rem;
		color: var(--gray-500);
		font-family: var(--font-mono);
		margin-top: 0.25rem;
	}

	.commit-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--success-fg);
		flex-shrink: 0;
	}
</style>
